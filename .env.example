# Copy to .env and source it OR use direnv / docker-compose env_file.

# ntfy.sh — topic libre (chaîne aléatoire pour pseudo-confidentialité)
# Crée ton topic en t'abonnant via l'app mobile ntfy.sh sur le même nom.
# Exemple : NTFY_TOPIC=hetzner-watch-d8x7q3
NTFY_TOPIC=

# Optionnel : serveur ntfy self-hosted
# NTFY_URL=https://ntfy.example.com

# Optionnel : token Bearer si ton topic est protégé
# NTFY_TOKEN=tk_xxx

# Discord webhook (alternative ou cumul avec ntfy)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK=
